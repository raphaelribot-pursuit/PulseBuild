# Copy this file to .env.local and fill in your real key.
# .env.local is gitignored — never commit real keys.

# Required for the Phase 7 chat layer (app/api/chat/route.ts).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-5

# Optional — only needed if you switch the "Voice src" toggle in the top
# bar to ElevenLabs (defaults to the free browser voice otherwise).
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional — defaults to the project's configured account voice if
# unset. Free-tier ElevenLabs accounts can only use voices already in
# your account (Voice Library IDs return 402 payment_required via the
# API on free tier) — find your voice IDs at
# https://elevenlabs.io/app/voice-lab
ELEVENLABS_VOICE_ID=

# Optional — defaults to eleven_turbo_v2_5 (fastest/cheapest per
# character, best fit for a free tier's limited monthly credits).
ELEVENLABS_MODEL_ID=
